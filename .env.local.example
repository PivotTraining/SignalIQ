# =============================================================================
# SignalIQ Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Supabase (Required) ---
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (Required) ---
# Get from: console.anthropic.com → API Keys
# Free tier: $5 credit on signup
ANTHROPIC_API_KEY=sk-ant-...

# --- Hunter.io (Required for email enrichment) ---
# Get from: hunter.io → Settings → API
# Free tier: 25 searches/month
HUNTER_API_KEY=your-hunter-key

# --- People Data Labs (Optional — contact enrichment) ---
# Get from: peopledatalabs.com → Dashboard
# Free tier: 100 person enrichments/month
PDL_API_KEY=your-pdl-key

# --- Google Custom Search (Optional — signal scanner) ---
# Get from: console.cloud.google.com → APIs → Custom Search JSON API
# Free tier: 100 queries/day
GOOGLE_NEWS_API_KEY=your-google-key
GOOGLE_NEWS_SEARCH_ENGINE_ID=your-search-engine-id

# --- Stripe (Required for billing) ---
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
